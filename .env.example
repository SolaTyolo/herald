# Herald 环境变量
# 复制后修改：cp .env.example .env
#
# 启动前加载（可选）：
#   set -a && source .env && set +a

# --- 核心 ---

# 本地开发：允许使用下方默认 ENCRYPTION_KEY
DEV_MODE=true

# API 监听地址（仅 API 进程）
HTTP_ADDR=:8080

# 必须为 32 字节；生产环境请自行生成：openssl rand -hex 16
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# WASM 插件目录（API 与 Worker 必须都能访问）
WASM_PLUGIN_DIR=./plugins/wasm

# Redis：Asynq 任务队列、限流；WORKER_API_PUBSUB=redis 时也用于 Worker↔API 事件桥
REDIS_ADDR=localhost:6379

# Worker ↔ API 事件总线（in_app 消息从 Worker 传到 API 以触发 subscriber webhook）
# redis | local | rabbitmq-http | kafka-http
WORKER_API_PUBSUB=redis

# rabbitmq-http：Management HTTP 发布 + sidecar SSE 订阅（cmd/rabbit-inapp-bridge）
# WORKER_API_RABBITMQ_HTTP_URL=http://rabbit:15672
# WORKER_API_RABBITMQ_USER=guest
# WORKER_API_RABBITMQ_PASS=guest
# WORKER_API_RABBITMQ_VHOST=/
# WORKER_API_RABBITMQ_EXCHANGE=herald.worker-api
# WORKER_API_RABBITMQ_ROUTING_KEY=events
# WORKER_API_RABBITMQ_STREAM_URL=http://localhost:8091/stream

# kafka-http：Redpanda / Confluent REST Proxy
# WORKER_API_KAFKA_HTTP_URL=http://redpanda:8082
# WORKER_API_KAFKA_TOPIC=herald.worker-api.events

# 旧变量名 INAPP_* 仍兼容，建议改用 WORKER_API_*

# Topic 触发时单次最大订阅者数
MAX_RECIPIENTS=100

# --- 存储 ---

# file = STORE_FILE_PATH 下 JSON 文件（无需数据库）
# db   = GORM + DB_DRIVER
STORE_TYPE=db

# postgres | mysql | sqlite（STORE_TYPE=db 时有效）
DB_DRIVER=postgres

# STORE_TYPE=db 时的 DSN（默认与 deploy/docker-compose.yml 中 Postgres 一致）
DATABASE_URL=postgres://herald:herald@localhost:5432/herald?sslmode=disable

# STORE_TYPE=file 时的数据目录（bootstrap.json + envs/）
STORE_FILE_PATH=./data

# --- 日志 ---

# debug | info | warn | error
LOG_LEVEL=info

# text | json
LOG_FORMAT=text

# --- OpenTelemetry（可选）---

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# 运行时由 bootstrap 覆盖为 herald-api / herald-worker
OTEL_SERVICE_NAME=herald
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true

# --- 快捷配置（取消注释其一）---

# 纯文件模式，无需 Postgres：
# STORE_TYPE=file
# STORE_FILE_PATH=./data

# MySQL：
# STORE_TYPE=db
# DB_DRIVER=mysql
# DATABASE_URL=herald:herald@tcp(localhost:3306)/herald?charset=utf8mb4&parseTime=True&Loc=Local

# GORM + SQLite 文件：
# STORE_TYPE=db
# DB_DRIVER=sqlite
# DATABASE_URL=./data/herald.db
